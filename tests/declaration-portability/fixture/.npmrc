# Reproduce the real downstream condition: pnpm's DEFAULT symlinked layout.
# This is the layout that triggers TS2742 for non-portable inferred types.
# Explicitly assert we are NOT using the `hoisted` linker workaround and that
# nothing is shamefully hoisted to the root of node_modules.
node-linker=isolated
shamefully-hoist=false
auto-install-peers=true
